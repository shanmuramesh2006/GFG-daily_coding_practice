class Solution {
    public int getSecondLargest(int[] arr) {
        int largest=Integer.MIN_VALUE;
        int secondlar=Integer.MIN_VALUE;
        for(int i=0;i<arr.length;i++)
        {
            if(arr[i]>largest){
                secondlar=largest;
                largest=arr[i];
            }
        else if(secondlar<arr[i]&&arr[i]!=largest)
        {
           secondlar=arr[i]; 
        }
        }
        if(secondlar==Integer.MIN_VALUE)
        {
            return -1;
        }
        return secondlar;

    }
}
