class Solution {
    public static int intersectSize(int a[], int b[]) {
        HashSet<Integer> num=new HashSet<>();
        int count=0;
        for(int i=0;i<a.length;i++)
        {
            num.add(a[i]);
        }
        for(int j=0;j<b.length;j++)
        {
            if(num.contains(b[j]))
            {
                count++;
            }
        }
        return count;
    }
}
