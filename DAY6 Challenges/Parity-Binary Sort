import java.util.*;
class hello
{
int t=sc.nextInt();
while(t>0)
{
int n=sc.nextInt();
ArrayList<Integer> even=new ArrayList<>();
ArrayList<Integer> odd=new ArrayList<>();
for(int i=0;i<n;i++)
{
int num=sc.nextInt();
int bit=Integer.bitCount(num);
if(bit%2==0)
{
even.add(num);
}
else
{
odd.add(num);
}
}
Collections.sort(even);
Collections.sort(odd);
for(int x:even)
{
System.out.print(x+" ");
}
for(int x:odd)
{
System.out.print(x:" ");
}
t=t-1;
}
}
}
}

