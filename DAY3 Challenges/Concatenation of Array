class Solution {
    public int[] getConcatenation(int[] nums) {
        int newarr[]=new int[nums.length];
        for(int i=0;i<nums.length;i++)
        {
            newarr[i]=nums[i];
        }
        int arr[]=new int[nums.length+newarr.length];
        int ind=0;
        for(int i=0;i<nums.length;i++)
        {
            arr[ind++]=nums[i];
        }
        for(int i=0;i<newarr.length;i++)
        {
            arr[ind++]=newarr[i];
        }
        return arr;
    }
}
