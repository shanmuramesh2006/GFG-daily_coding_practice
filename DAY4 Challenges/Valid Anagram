class Solution {
    public boolean isAnagram(String s, String t) {
        if(s.length()!=t.length())
        {
            return false;
        }
        char[] sh=s.toCharArray();
        char[] ch=t.toCharArray();
        Arrays.sort(sh);
        Arrays.sort(ch);
        return Arrays.equals(sh,ch);
    }
}
